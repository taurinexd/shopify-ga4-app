# Shopify (auto-populated by `shopify app dev` linking)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=write_products

# GA4 Measurement Protocol (relay endpoint)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Dev/test
SHOPIFY_DEV_STORE_URL=
STOREFRONT_PASSWORD=

# Optional dev/incident-only relay diagnostics (off in prod).
# GA4_DEBUG_MODE=1 → relay injects `debug_mode: 1` in every event so GA4
# routes them to DebugView (bypasses bot/spam post-ingest filter).
# GA4_DUMP_PAYLOAD=1 → relay logs the full forwarded mpBody to stdout
# (Vercel logs) so you can correlate silent drops with field values.
# See README §9 last two entries for context.
GA4_DEBUG_MODE=
GA4_DUMP_PAYLOAD=
